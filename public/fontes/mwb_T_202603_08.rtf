s1\alang1046\af2\ai\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 ip-2}{\rtlch\fcs1\alang1046\af2\ai\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\i  }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 269 }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 par\u225?grafos}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2  }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 14 a 16}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 )\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\li720 {\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1033\langfenp1033\f2\cf2 [Texto inserido:] }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Isa\u237?as cap\u237?tulo 57 vers\u237?culo 13}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1033\langfenp1033\f2\cf2 : Quando voc\u234? gritar por socorro, Os \u237?dolos que voc\u234? juntou n\u227?o a salvar\u227?o. Um vento levar\u225? embora a todos eles, Um simples sopro os levar\u225? embora, Mas aquele que se refugiar em mim herdar\u225? esta terra E tomar\u225? posse do meu santo monte. [Fim do texto.]\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql {\rtlch\fcs1\alang1046\af1\ai\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf5 ip-2}{\rtlch\fcs1\alang1046\af1\ai\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf5\i  }{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf5 269 }{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 par\u225?grafos}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf5  }{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 14 a 16\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 14 Mas o per\u237?odo de longanimidade de Deus terminaria. Referindo-se a esse tempo, Jeov\u225? declara: \u8220?Eu mesmo \u233? que contarei a tua justi\u231?a e os teus trabalhos, que eles n\u227?o te aproveitar\u227?o. Quando clamares por socorro, a tua cole\u231?\u227?o de coisas n\u227?o te livrar\u225?, mas um vento carregar\u225? mesmo com todas elas. Uma exala\u231?\u227?o as levar\u225? embora.\u8221? (}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Isa\u237?as cap\u237?tulo 57 vers\u237?culos 12, 1}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 3a) Jeov\u225? exporia a falsa justi\u231?a de Jud\u225?. Seus trabalhos hip\u243?critas n\u227?o trariam nenhum benef\u237?cio. A sua \u8220?cole\u231?\u227?o de coisas\u8221?, seu estoque de \u237?dolos, n\u227?o a livraria. Quando a calamidade assolasse, os deuses em quem ela confiava seriam varridos por um mero sopro de vento.\par}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 15 As palavras de Jeov\u225? se cumpriram em 607}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2  antes da era comum}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 . Foi quando o rei babil\u244?nio Nabucodonosor destruiu Jerusal\u233?m, incendiou o templo e levou a maior parte do povo como cativos. \u8220?Assim foi exilado Jud\u225? do seu solo.\u8221? \u8212? }{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Segundo Reis cap\u237?tulo 25 vers\u237?culos 1 a 21}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 .\par}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 16 Similarmente, o grande estoque de \u237?dolos da cristandade n\u227?o a livrar\u225? no dia da ira de Jeov\u225?. (}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Isa\u237?as cap\u237?tulo 2 vers\u237?culos 19 a 22}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 ; }{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Segunda Tessalonicenses cap\u237?tulo 1 vers\u237?culos 6 a 10}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 ) Junto com o restante de \u8220?Babil\u244?nia, a Grande\u8221?, o conjunto de religi\u245?es falsas do mundo, a cristandade ser\u225? aniquilada. A simb\u243?lica fera cor de escarlate e seus dez chifres deixar\u227?o Babil\u244?nia, a Grande, \u8216?devastada e nua, comer\u227?o as suas carnes e a queimar\u227?o completamente no fogo\u8217?. (}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Revela\u231?\u227?o cap\u237?tulo 17 vers\u237?culos 3, 16, 1}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 7) Como somos gratos de termos obedecido \u224? ordem: \u8220?Sa\u237? dela, povo meu, se n\u227?o quiserdes compartilhar com ela nos seus pecados e se n\u227?o quiserdes receber parte das suas pragas\u8221?! (}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Revela\u231?\u227?o cap\u237?tulo 18 vers\u237?culos 4, 5}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 ) Jamais retornemos a ela ou \u224?s suas pr\u225?ticas!\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql {\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1033\langfenp1033\f2\cf2 [Fim da mat\u233?ria de refer\u234?ncia.]\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\fi576 {\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 As pessoas que n\u227?o t\u234?m Jeov\u225? ficam inquietas e divididas. (}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Isa\u237?as cap\u237?tulo 57 vers\u237?culo 2}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 0; }{\rtlch\fcs1\alang1046\af2\ai\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 w18.06}{\rtlch\fcs1\alang1046\af2\ai\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\i  }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 7 }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 par\u225?grafo}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2  16; }{\rtlch\fcs1\alang1046\af2\ai\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 it }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 \u8220?Terra\u8221? }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 par\u225?grafo}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2 \u160?21)\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql\li720 {\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1033\langfenp1033\f2\cf2 [Texto inserido:] }{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf2 Isa\u237?as cap\u237?tulo 57 vers\u237?culo 20}{\rtlch\fcs1\alang1046\af2\ltrch\fcs0\lang1046\langnp1046\langfe1033\langfenp1033\f2\cf2 : \u8220?Mas os maus s\u227?o como o mar agitado que n\u227?o se acalma, E suas \u225?guas trazem \u224? tona algas e lama. [Fim do texto.]\par}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1033\langfenp1033\f2\cf2 [Imagem:]\u160?Duas irm\u227?s est\u227?o trabalhando juntas no campo com alegria.\par}\pard\plain\langnp1033\langfenp1033 \ltrpar\ql {\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\langfe1046\langfenp1046\f2\cf5 w18.06}{\rtlch\fcs1\alang1046\af1\ltrch\fcs0\lang1046\langnp1046\lang